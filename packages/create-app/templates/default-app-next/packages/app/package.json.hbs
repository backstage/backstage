{
  "name": "app",
  "version": "0.0.0",
  "backstage": {
    "role": "frontend"
  },
  "private": true,
  "files": [
    "dist"
  ]
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
